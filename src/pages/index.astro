---
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Curtis's Blog</title>
  <meta name="description" content="A static reconstruction of Davis Blocks for Cloudflare Pages.">
  <link rel="stylesheet" href="/assets/site.css">
</head>
<body>
  <div class="site-shell">
    <header class="site-header stack">
      <div class="nav-shell">
        <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="primary-nav">Menu</button>
        <nav class="nav" id="primary-nav" data-primary-nav aria-label="Primary">
          <a href="/life.html">生活</a>
          <a href="/tech.html">技术</a>
          <a href="/page/about.html">关于</a>
        </nav>
      </div>

      <div class="brand">
        <h1><a href="/">Curtis's Blog</a></h1>
        <p>A clean and lightweight static blog</p>
      </div>
    </header>

    <main class="stack">
      <header class="archive-header" data-archive-title="config">
        <h2>归档</h2>
      </header>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <time>{post.data.date ? new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric' }) : ''}</time>
            &nbsp; <a href={`/posts/${post.slug}/`}>{post.data.title || post.slug}</a>
          </li>
        ))}
      </ul>
      <nav class="pagination" data-pagination aria-label="Pagination"></nav>
    </main>

    <footer class="site-footer stack">
      <div class="separator-wrap">
        <hr class="davis-separator">
      </div>
      <p>© <span data-year></span> Curtis's Blog</p>
    </footer>
  </div>

  <script src="/assets/site.js?v=20260520b" defer></script>
</body>
</html>
