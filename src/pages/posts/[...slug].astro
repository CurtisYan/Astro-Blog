---
import { getCollection } from 'astro:content';
import { getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
  return posts
    .map((post) => {
      const slugValue = String(post.slug || post.id || '').trim();
      if (!slugValue) {
        return null;
      }
      return {
        params: { slug: slugValue }
      };
    })
    .filter(Boolean);
}

const slugParam = Array.isArray(Astro.params.slug) ? Astro.params.slug.join('/') : Astro.params.slug;
const post = await getEntry('posts', slugParam);
if (!post) throw new Error(`Post not found: ${slugParam}`);
const { Content } = await render(post);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} | Curtis's Blog</title>
    <link rel="stylesheet" href="/assets/site.css">
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header stack">
        <div class="nav-shell">
          <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="primary-nav">菜单</button>
          <nav class="nav" id="primary-nav" data-primary-nav aria-label="Primary">
            <a href="/life.html">生活</a>
            <a href="/tech.html">技术</a>
            <a href="/page/about.html">关于</a>
          </nav>
        </div>
        <div class="brand">
          <h1><a href="/">Curtis's Blog</a></h1>
        </div>
      </header>
      <main class="article">
        <h1>{post.data.title}</h1>
        <p class="post-meta">{post.data.date}</p>
        <Content />
      </main>
      <footer class="site-footer stack">
        <p>© <span data-year></span> Curtis's Blog</p>
      </footer>
    </div>
  </body>
</html>
